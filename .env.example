# ============================================
# Database — Neon Postgres (https://neon.tech)
# ============================================
# 1. Create project at neon.tech
# 2. Copy connection string from "Connection Details"
# 3. Paste here and save as .env
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/elitecarmats?sslmode=require"

# ============================================
# Admin panel — /admin
# ============================================
# Password for the admin panel (min 6 chars). Choose a strong one.
ADMIN_PASSWORD="change-me-to-strong-password"

# ============================================
# Email — Resend (https://resend.com)
# ============================================
# If RESEND_API_KEY is not set, emails will be logged to console only.
# 1. Sign up at resend.com (free tier: 3000 emails/month)
# 2. Create API key and paste here
# 3. Verify the elitecarmats.us domain in Resend dashboard
#    (add the DNS records in Vercel → Domains → DNS)
RESEND_API_KEY=""

# Sender address. Must be from a verified domain.
# Before domain is verified, use: "EliteCarMats <onboarding@resend.dev>"
EMAIL_FROM="EliteCarMats <orders@elitecarmats.us>"

# Where new order notifications go
OWNER_EMAIL="info@elitecarmats.us"

# ============================================
# Site URL — used in email links
# ============================================
NEXT_PUBLIC_SITE_URL="https://elitecarmats.us"
