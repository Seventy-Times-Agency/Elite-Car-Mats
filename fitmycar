<script>
    require([
        'jquery',
        'mage/validation',
        'domReady!'
    ], function ($) {
        $(document).ready(function(){
            var form = $('.footer-subscribe-form');
            form.submit(function(e){
                e.preventDefault();
                if(form.valid()){
                    $('.newsletter .footer-subscribe-message.success > div').empty();
                    $('.newsletter .footer-subscribe-message.error > div').empty();
                    $('.newsletter .footer-subscribe-message.error').hide();
                    $('.newsletter .footer-subscribe-message.success').hide();
                    var formData = form.serialize();
                    $.ajax({
                        url: form.attr('action'),
                        method: 'POST',
                        data: formData,
                        beforeSend: function () {
                            $('.ajax-loader').show();
                        },
                    }).done(function (reponse) {
                        if (reponse.success == '1') {
                            $('.newsletter .footer-subscribe-message.success > div').text(reponse.message);
                            $('.ajax-loader').hide();
                            $('.footer-subscribe-button').removeAttr('disabled');
                            $('.newsletter .footer-subscribe-message.success').show();

                            setTimeout(function(){
                                $('.newsletter .footer-subscribe-message.success').hide();
                            }, 10000);

                        } else if (reponse.success == '0' && reponse.message != '') {
                            $('.newsletter .footer-subscribe-message.error > div').text(reponse.message);
                            $('.ajax-loader').hide();
                            $('.footer-subscribe-button').removeAttr('disabled');
                            $('.newsletter .footer-subscribe-message.error').show();

                            setTimeout(function(){
                                $('.newsletter .footer-subscribe-message.error').hide();
                            }, 10000);
                        }
                    }).fail(function (jqXHR, textStatus) {
                        if (window.console) {
                            console.log(textStatus);
                        }
                    });
                }
            })
        });
    });
</script>
